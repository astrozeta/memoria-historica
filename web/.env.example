# Postgres connection
# - En Netlify (producción): NETLIFY_DATABASE_URL se inyecta automáticamente.
# - En desarrollo local con Netlify Dev: también se inyecta automáticamente.
# - Para desarrollo local sin Netlify Dev: define DATABASE_URL apuntando a tu
#   Postgres local (Docker, Neon directo, etc.).
DATABASE_URL="postgres://user:password@host:5432/dbname?sslmode=require"

# Auth.js secret (genera con: openssl rand -base64 32)
AUTH_SECRET=""

# Email para magic links (Resend o equivalente)
AUTH_RESEND_KEY=""
AUTH_RESEND_FROM="hola@example.com"

# URL pública del sitio (en dev: http://localhost:3000)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Secret para endpoints administrativos (POST /api/admin/ingest/*).
# Genera con: openssl rand -base64 32
INGEST_SECRET=""
